{
  "name": "chatmark-qq",
  "version": "0.1.0",
  "description": "A local-first annotation tool for QQ chat exports, designed for conversation review and LLM fine-tuning dataset creation.",
  "author": "hedssaz",
  "type": "module",
  "main": "desktop/main.mjs",
  "scripts": {
    "start": "node server.mjs",
    "desktop": "electron .",
    "dist:win": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.hedssaz.chatmarkqq",
    "productName": "chatmark-qq",
    "files": [
      "desktop/**/*",
      "public/**/*",
      "server.mjs",
      "package.json",
      "README.md",
      "LICENSE"
    ],
    "directories": {
      "output": "dist"
    },
    "asar": true,
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "devDependencies": {
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1"
  }
}
